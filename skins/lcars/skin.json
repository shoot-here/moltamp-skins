{
  "id": "lcars",
  "name": "LCARS",
  "version": "1.0.0",
  "author": "Moltamp",
  "description": "Federation starship console. Warm peach, gold, and lavender. Rounded pill shapes. Make it so.",
  "engine": "1.0",
  "effects": {
    "glow": true,
    "vibes-pulse":  { "label": "Vibes Pulse",    "description": "Gentle brightness pulse on LCARS vibes modules" },
    "ticker":       { "label": "Status Ticker",   "description": "Scrolling stardate readout and blinking status indicators" },
    "ambient":      { "label": "Ambient Glow",    "description": "Slow-cycling color wash across the shell" }
  },
  "vibes": {
    "slots": [
      { "widgetId": "gif", "gifSrc": "assets/vibes.gif", "gifFit": "cover" }
    ]
  },
  "defaultLayout": {
    "tabAssignments": {
      "intel": ["events", "agents", "git", "files"],
      "signal": ["custom-1", "custom-2", "custom-3", "custom-4"]
    },
    "tabVisibility": {
      "events": true, "files": false, "agents": true, "git": true,
      "custom-1": true, "custom-2": true, "custom-3": true, "custom-4": true
    },
    "customTabs": {
      "custom-1": { "label": "SENSORS", "widgets": ["system", "weather"] },
      "custom-2": { "label": "COMMS", "widgets": ["music", "visualizer"] },
      "custom-3": { "label": "HOLODECK", "widgets": ["live2d", "event-calendar"] },
      "custom-4": { "label": "DIAGNOSTICS", "widgets": ["usage-model", "usage-context", "usage-tokens", "usage-session", "usage-rates", "usage-lifetime"] }
    },
    "dimensions": {
      "leftWidth": 240,
      "rightWidth": 220,
      "vibesHeight": 180,
      "bottomHeight": 26,
      "panelScale": 1,
      "terminalScale": 1
    },
    "panelVisibility": {
      "showVibes": true,
      "showLeft": true,
      "showRight": true,
      "showBottom": true
    },
    "vibesDeck": {
      "slots": [
        { "gifSrc": "assets/vibes.gif", "gifFit": "cover" },
        { "widgetId": "system" },
        { "widgetId": "weather" },
        { "widgetId": "world-clock" }
      ],
      "widths": [40, 20, 20, 20]
    }
  }
}
