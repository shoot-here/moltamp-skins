{
  "id": "kosmos",
  "name": "Kosmos",
  "version": "1.0.0",
  "author": "Moltamp",
  "description": "Soviet mission control. Amber on dark green. Orbital trajectories. Utilitarian and beautiful.",
  "engine": "1.0",
  "effects": {
    "scanlines": true,
    "glow": true,
    "crt": true,
    "grid": true,
    "orbit": { "label": "Orbit Glow", "description": "Rotating orbital trajectory in vibes panel" },
    "ticker": { "label": "Cyrillic Ticker", "description": "Scrolling telemetry text and beacon in bottom panel" },
    "vibes-pulse": { "label": "Vibes Pulse", "description": "Brightness pulse and glow on high activity" }
  },
  "vibes": {
    "slots": [
      { "widgetId": "gif", "gifSrc": "assets/vibes.gif", "gifFit": "cover" }
    ]
  },
  "defaultLayout": {
    "tabAssignments": {
      "intel": ["events", "files", "agents", "git"],
      "signal": ["custom-1", "custom-2", "custom-3"]
    },
    "tabVisibility": {
      "events": true, "files": true, "agents": true, "git": true,
      "custom-1": true, "custom-2": true, "custom-3": true, "custom-4": false
    },
    "customTabs": {
      "custom-1": { "label": "KONTROL", "widgets": ["system", "clock", "world-clock", "weather"] },
      "custom-2": { "label": "SVYAZ", "widgets": ["music", "visualizer", "equalizer"] },
      "custom-3": { "label": "DANNIE", "widgets": ["usage-model", "usage-context", "usage-tokens", "usage-session", "usage-rates", "usage-lifetime", "calendar"] },
      "custom-4": { "label": "KOSMONAUT", "widgets": ["live2d"] }
    },
    "dimensions": {
      "leftWidth": 290,
      "rightWidth": 200,
      "vibesHeight": 150,
      "bottomHeight": 26,
      "panelScale": 1,
      "terminalScale": 1
    },
    "panelVisibility": {
      "showVibes": true,
      "showLeft": true,
      "showRight": true,
      "showBottom": true
    },
    "vibesDeck": {
      "slots": [
        { "gifSrc": "assets/vibes.gif", "gifFit": "cover" },
        { "widgetId": "clock" }
      ],
      "widths": [65, 35]
    }
  }
}
