{
  "id": "ice-nine",
  "name": "Ice Nine",
  "version": "1.0.0",
  "author": "Moltamp",
  "description": "Cold blue terminal. Frosted glass edges. Breathing cyan glow. Everything crystallizes.",
  "engine": "1.0",
  "effects": {
    "scanlines": true,
    "glow": true,
    "vibes-glow": { "label": "Vibes Glow", "description": "Breathing cyan glow on vibes panel during high activity" },
    "edge-pulse": { "label": "Edge Pulse", "description": "Pulsing cyan accent line on terminal top edge" }
  },
  "vibes": {
    "slots": [
      { "widgetId": "gif", "gifSrc": "assets/vibes.gif", "gifFit": "cover" }
    ]
  },
  "defaultLayout": {
    "tabAssignments": {
      "intel": ["events", "files", "agents", "git"],
      "signal": ["custom-1", "custom-2", "custom-3", "custom-4"]
    },
    "tabVisibility": {
      "events": true, "files": true, "agents": true, "git": true,
      "custom-1": false, "custom-2": false, "custom-3": false, "custom-4": false
    },
    "customTabs": {
      "custom-1": { "label": "CORE", "widgets": ["clock", "session-timer", "calendar"] },
      "custom-2": { "label": "RESONANCE", "widgets": ["visualizer", "equalizer"] },
      "custom-3": { "label": "CRYO", "widgets": ["live2d"] },
      "custom-4": { "label": "ANALYSIS", "widgets": ["usage-model", "usage-context", "usage-tokens", "usage-session", "usage-rates", "usage-lifetime"] }
    },
    "dimensions": {
      "leftWidth": 280,
      "rightWidth": 170,
      "vibesHeight": 130,
      "bottomHeight": 26,
      "panelScale": 1,
      "terminalScale": 1
    },
    "panelVisibility": {
      "showVibes": true,
      "showLeft": true,
      "showRight": false,
      "showBottom": true
    },
    "vibesDeck": {
      "slots": [
        { "gifSrc": "assets/vibes.gif", "gifFit": "cover" },
        { "widgetId": "clock" }
      ],
      "widths": [70, 30]
    }
  }
}
