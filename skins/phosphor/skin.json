{
  "id": "phosphor",
  "name": "Phosphor",
  "version": "1.0.0",
  "author": "Moltamp",
  "description": "Green phosphor CRT. Scanlines, glow, and grid decay. Feels like hacking in 1983.",
  "engine": "1.0",
  "effects": {
    "scanlines": true,
    "glow": true,
    "crt": true,
    "grid": true,
    "text-glow": true
  },
  "vibes": {
    "slots": [
      { "widgetId": "gif", "gifSrc": "assets/vibes.gif", "gifFit": "cover" }
    ]
  },
  "defaultLayout": {
    "tabAssignments": {
      "intel": ["events", "git", "agents", "files"],
      "signal": ["custom-1", "custom-2", "custom-3", "custom-4"]
    },
    "tabVisibility": {
      "events": true, "files": false, "agents": false, "git": true,
      "custom-1": false, "custom-2": false, "custom-3": false, "custom-4": false
    },
    "customTabs": {
      "custom-1": { "label": "TERMINAL", "widgets": ["clock", "session-timer"] },
      "custom-2": { "label": "AUDIO", "widgets": ["music", "equalizer"] },
      "custom-3": { "label": "DISPLAY", "widgets": ["live2d"] },
      "custom-4": { "label": "SYSTEM", "widgets": ["usage-model", "usage-context", "usage-tokens", "usage-session", "usage-rates"] }
    },
    "dimensions": {
      "leftWidth": 260,
      "rightWidth": 160,
      "vibesHeight": 140,
      "bottomHeight": 26,
      "panelScale": 1,
      "terminalScale": 1
    },
    "panelVisibility": {
      "showVibes": false,
      "showLeft": true,
      "showRight": false,
      "showBottom": true
    }
  }
}
