{
  "id": "obsidian",
  "name": "Obsidian",
  "version": "1.0.0",
  "author": "Moltamp",
  "description": "Deep black terminal with amber accents. Inspired by volcanic glass.",
  "engine": "1.0",
  "effects": {
    "scanlines": true
  },
  "vibes": {
    "slots": [
      { "widgetId": "gif", "gifSrc": "assets/vibes.gif", "gifFit": "cover" }
    ]
  },
  "defaultLayout": {
    "tabAssignments": {
      "intel": ["events", "files", "agents", "git"],
      "signal": ["custom-1", "custom-2", "custom-3", "custom-4"]
    },
    "tabVisibility": {
      "events": true, "files": true, "agents": true, "git": true,
      "custom-1": true, "custom-2": true, "custom-3": true, "custom-4": true
    },
    "customTabs": {
      "custom-1": { "label": "TOOLKIT", "widgets": ["clock", "notes", "session-timer", "calendar", "weather"] },
      "custom-2": { "label": "AUDIO", "widgets": ["music", "visualizer", "equalizer"] },
      "custom-3": { "label": "COMPANION", "widgets": ["live2d", "event-calendar", "world-clock"] },
      "custom-4": { "label": "METRICS", "widgets": ["usage-model", "usage-context", "usage-tokens", "usage-session", "usage-rates", "usage-lifetime", "system"] }
    },
    "dimensions": {
      "leftWidth": 280,
      "rightWidth": 210,
      "vibesHeight": 120,
      "bottomHeight": 26,
      "panelScale": 1,
      "terminalScale": 1
    },
    "panelVisibility": {
      "showVibes": true,
      "showLeft": true,
      "showRight": true,
      "showBottom": true
    },
    "vibesDeck": {
      "slots": [
        { "gifSrc": "assets/vibes.gif", "gifFit": "cover" },
        { "widgetId": "notes" }
      ],
      "widths": [60, 40]
    }
  }
}
